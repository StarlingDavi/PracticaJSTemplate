<div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
    <div class="team-item">
        <div class="team-body">
            <div class="team-before">
                <span>Age</span>
                <span>Height</span>
                <span>Weight</span>
                <span>Bust</span>
                <span>Waist</span>
                <span>Hips</span>
            </div>
            <img class="img-fluid" src="<%= modelo.imagen %>" alt="<%= modelo.nombre %>">
            <div class="team-after">
                <span><%= modelo.edad %></span>
                <span><%= modelo.altura %></span>
                <span><%= modelo.peso %></span>
                <span><%= modelo.busto %></span>
                <span><%= modelo.cintura %></span>
                <span><%= modelo.caderas %></span>
            </div>
        </div>
        <a class="team-name" href="#">
            <h5 class="text-uppercase mb-0"><%= modelo.nombre %></h5>
        </a>
    </div>
</div>
